      "id": "0ab5452b-1209-4717-835a-02cafc7432f1",
      "name": "Anomaly Found?"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all().map(i => i.json);\n\n// ODFILTRUJ TYLKO POPRAWNE ANOMALIE (z symbolem i ceną)\nconst anomalies = items.filter(i => i.symbol && i.price_usd && !isNaN(parseFloat(i.price_usd)));\n\n// ODFILTRUJ TYLKO POPRAWNE WYJAŚNIENIA (z explanation, bez symbolu)\nconst explanations = items.filter(i => i.explanation && !i.symbol);\n\nconsole.log(`Znaleziono ${anomalies.length} anomalii i ${explanations.length} wyjaśnień`);\n\n// Weź tylko tyle wyjaśnień ile jest anomalii\nconst limitedExplanations = explanations.slice(0, anomalies.length);\n\n// Zbuduj listę anomalii (bez wyjaśnień w środku)\nconst anomalyLines = anomalies.map(a => {\n  const price = parseFloat(a.price_usd).toFixed(2);\n  const change = parseFloat(a.price_change_24h).toFixed(2);\n  return `${a.symbol}: USD ${price} | change 24h: ${change}%`;\n}).join('\\n');\n\n// Zbuduj listę wyjaśnień (osobno, na dole)\nconst explanationLines = limitedExplanations.map((e, idx) => {\n  return `${idx+1}. ${e.explanation}`;\n}).join('\\n\\n---\\n\\n');\n\n// Połącz wiadomość\nconst message = `⚠️ *ANOMALIE CENOWE (${anomalies.length})*\\n\\n${anomalyLines}\\n\\n---\\n🤖 *WYJAŚNIENIA:*\\n\\n${explanationLines}`;\n\n// Zapisz wszystko do bazy\nconst allExplanations = limitedExplanations.map(e => e.explanation).join('\\n---\\n');\n\nconst content = JSON.stringify({\n  alert_type: 'price_anomaly',\n  affected_symbols: anomalies.map(a => a.symbol),\n  message: message,\n  detailed_explanations: allExplanations,\n  detected_at: new Date().toISOString()\n}).replace(/'/g, \"''\");\n\nreturn [{\n  json: {\n    query: `INSERT INTO ai_insights (insight_type, content, generated_at) VALUES ('price_anomaly', '${content}'::jsonb, NOW())`,\n    affected_symbols: anomalies.map(a => a.symbol),\n    message: message,\n    explanation: allExplanations\n  }\n}];"
      },
