    {
      "parameters": {
        "jsCode": "// Formatowanie odpowiedzi z GET AI Daily Summary do wiadomości Telegram\nconst data = $input.first().json;\n\n// Pobierz pola z odpowiedzi API\nconst summary = data.summary || 'Brak podsumowania';\nconst insights = data.insights || [];\nconst recommendations = data.recommendations || [];\nconst generatedAt = data.generated_at ? new Date(data.generated_at).toLocaleString('pl-PL') : 'przed chwilą';\n\n// Zbuduj wiadomość w formacie podobnym do anomalii\nlet message = `📊 *PODSUMOWANIE GODZINOWE* 📊\\n\\n`;\nmessage += `*${summary}*\\n\\n`;\nmessage += `🔍 *Najważniejsze spostrzeżenia:*\\n`;\ninsights.forEach((insight, i) => {\n  message += `${i+1}. ${insight}\\n`;\n});\nmessage += `\\n💡 *Rekomendacje:*\\n`;\nrecommendations.forEach((rec, i) => {\n  message += `${i+1}. ${rec}\\n`;\n});\nmessage += `\\n⏱️ *Wygenerowano:* ${generatedAt}`;\n\n// Zwróć dane dla węzła Telegram\nreturn {\n  json: {\n    chat_id: \"YOUR_TELEGRAM_CHAT_ID\",\n    text: message,\n    parse_mode: \"Markdown\"\n  }\n};"
      },
