# =================================================================
# AI-Powered BI Dashboard - Environment Configuration Example
# =================================================================
# Instrukcja: Skopiuj ten plik jako .env i uzupełnij klucze API.
# Plik .env jest ignorowany przez git dla zachowania bezpieczeństwa.

# -----------------------------------------------------------------
# 1. POSTGRESQL DATABASE CONFIGURATION
# -----------------------------------------------------------------
# Dane dostępowe do bazy danych PostgreSQL (używane przez Docker & Backend)
POSTGRES_USER=dashboard_admin
POSTGRES_PASSWORD=change_me_in_production_123
POSTGRES_DB=business_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------
# 2. EXTERNAL API KEYS (DATA SOURCES)
# -----------------------------------------------------------------


# GROQ AI 
GROQ_API_KEY=your_groq_api_key_here

# binance API (Kryptowaluty)
BINANCE_API_URL=https://api.binance.com/api/v3

# OpenWeather API (Dane pogodowe)
# Rejestracja: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# NewsAPI (Wiadomości rynkowe)
# Rejestracja: https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# Alpha Vantage (Giełda: Akcje i Forex)
# Rejestracja: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your_alphavantage_key_here

# -----------------------------------------------------------------
# 3. N8N WORKFLOW AUTOMATION
# -----------------------------------------------------------------
# Konfiguracja automatyzacji n8n
N8N_HOST=n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin_secret_password

# -----------------------------------------------------------------
# 4. INFRASTRUCTURE & NETWORK
# -----------------------------------------------------------------

# Backend (FastAPI)
BACKEND_PORT=8000

# Frontend (React)
# UWAGA: localhost:8000 działa, gdy uruchamiasz przeglądarkę na tej samej maszynie co Docker
REACT_APP_API_URL=http://localhost:8000

# =================================================================
# QUICK START GUIDE:
# =================================================================
# 1. cp .env.example .env
# 2. Uzupełnij GEMINI_API_KEY (kluczowy dla modułu AI)
# 3. docker-compose up -d --build
#
# USŁUGI:
# - Dashboard (UI): http://localhost:3000
# - API Documentation: http://localhost:8000/docs
# - Automation (n8n): http://localhost:5678
# =================================================================