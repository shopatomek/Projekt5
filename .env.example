# =================================================================
# AI-Powered BI Dashboard - Environment Configuration
# =================================================================
# Quick start:
#   1. cp .env.example .env
#   2. Fill in GROQ_API_KEY (required)
#   3. Fill in TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID
#   4. docker compose up -d --build
#
# Available services after startup:
#   - Frontend (React): http://localhost:3000
#   - Backend API:      http://localhost:8000/docs
#   - n8n:              http://localhost:5678 first-run setup — see N8N_SETUP_AND_ARCHITECTURE.md)
#   - pgAdmin:          http://localhost:5050 (first-run setup)
#   - Metabase BI:      http://localhost:3001 (first-run setup)
# =================================================================

# -----------------------------------------------------------------
# 1. POSTGRESQL DATABASE CONFIGURATION
# -----------------------------------------------------------------
# ⚠️ IMPORTANT: Change these passwords before production deployment!
# Generate strong passwords using: openssl rand -base64 32
POSTGRES_USER=dashboarduser
POSTGRES_PASSWORD=xK9mP2nQ5rS8tU1vW3yZ4aB7cD0eF6gH
POSTGRES_DB=business_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------
# 2. PgAdmin - Database Management
# -----------------------------------------------------------------
# ⚠️ IMPORTANT: Change these credentials before production!
PGADMIN_EMAIL=admin@dashboard.local
PGADMIN_PASSWORD=jL8kM2nP5rS7tU1vW3xZ4aB6cD9eF0gH

# -----------------------------------------------------------------
# 3. API KEYS - External Services
# -----------------------------------------------------------------
# GROQ AI (required for AI insights, trend analysis, anomaly explanation)
# Get your key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Binance API (cryptocurrency data - used by backend scheduler)
BINANCE_API_URL=https://api.binance.com/api/v3

# -----------------------------------------------------------------
# 4. n8n Workflow Automation
# -----------------------------------------------------------------
# ⚠️ IMPORTANT: Change these credentials before production!
N8N_HOST=n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=aR4tU8xZ1cF3gH5jK7lM9nP2sV6yB0eW

# Telegram alerts (optional - for anomaly alerts and daily summaries)
# 1. Create a bot via @BotFather -> you'll get a token
# 2. Find your chat_id (e.g., via @userinfobot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------
# 5. Backend (FastAPI)
# -----------------------------------------------------------------
BACKEND_PORT=8000

# -----------------------------------------------------------------
# 6. Frontend (React)
# -----------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8000

# -----------------------------------------------------------------
# 7. Metabase BI (optional - configured via UI, not env)
# -----------------------------------------------------------------
# Metabase is configured through the web interface after first run.
# The metabase_app database is created automatically by init-metabase.sh.
# Access: http://localhost:3001

# =================================================================
# SECURITY NOTES:
# =================================================================
# 1. CHANGE all default passwords before production deployment!
#    The passwords above are EXAMPLES only - generate your own using:
#    - Linux/Mac: openssl rand -base64 32
#    - Windows:  [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# 2. NEVER commit .env to the repository (it's in .gitignore)
# 3. In production, use a reverse proxy with HTTPS (e.g., Caddy, Traefik)
# 4. Telegram alerts only work when both TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are set
# 5. Use different passwords for different environments (dev/staging/prod)
# 6. Rotate passwords periodically (every 90 days recommended)
# =================================================================