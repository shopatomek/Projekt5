# =================================================================
# AI-Powered BI Dashboard - Environment Configuration
# =================================================================

QUICK START:

1. cp .env.example .env
2. Uzupełnij GROQ_API_KEY (kluczowy dla modułu AI)
3. docker compose up -d --build

USŁUGI:
- Frontend (React): http://localhost:3000
- Backend API:      http://localhost:8000/docs
- n8n:              http://localhost:5678
- pgAdmin:          http://localhost:5050
- Metabase BI:      http://localhost:3001

# -----------------------------------------------------------------
# 1. POSTGRESQL DATABASE CONFIGURATION
# -----------------------------------------------------------------
POSTGRES_USER=dashboard_admin
POSTGRES_PASSWORD=StrongPassword123!
POSTGRES_DB=business_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------
# 2. PgAdmin - Database Management
# -----------------------------------------------------------------
PGADMIN_EMAIL=admin@dashboard.local
PGADMIN_PASSWORD=admin123

# -----------------------------------------------------------------
# 3. API KEYS - External Data Sources
# -----------------------------------------------------------------
# GROQ AI (required for AI insights)
GROQ_API_KEY=your_groq_api_key_here

# Binance API (cryptocurrency data)
BINANCE_API_URL=https://api.binance.com/api/v3

# Alpha Vantage (stocks, forex) - optional
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# -----------------------------------------------------------------
# 4. n8n Workflow Automation
# -----------------------------------------------------------------
N8N_HOST=n8n
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=n8n_secret_123

# -----------------------------------------------------------------
# 5. Backend (FastAPI)
# -----------------------------------------------------------------
BACKEND_PORT=8000

# -----------------------------------------------------------------
# 6. Frontend (React)
# -----------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8000

# =========================================================
